# OpenAI assistant configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Optional: override the Responses API URL only if needed
# OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# API hardening and persistence
# AETHERSENTRIX_API_TOKEN=replace_with_a_long_random_token
# AETHERSENTRIX_RATE_LIMIT_PER_MINUTE=240
# AETHERSENTRIX_MAX_BODY_BYTES=1048576
# AETHERSENTRIX_PERSIST_EVENTS=true
# AETHERSENTRIX_PERSIST_ALERTS=true
# AETHERSENTRIX_EVENT_ARCHIVE_PATH=data/events.jsonl
# AETHERSENTRIX_ALERT_ARCHIVE_PATH=data/alerts.jsonl

# MLOps note:
# Place local real-dataset CSV files under data/datasets/
# Trained model artifacts are stored under data/model_registry/
